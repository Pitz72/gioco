{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist-electron",
    "module": "commonjs",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom"
    ],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "moduleResolution": "node",
    "allowImportingTsExtensions": false
  },
  "include": [
    "main.ts",
    "preload.ts"
  ]
}
